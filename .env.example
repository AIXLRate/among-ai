# Among-AI Environment Variables
# Copy this file to .env and fill in your values

# Groq API Key - Get yours at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model used for debate synthesis (default: llama-3.1-8b-instant)
# SYNTHESIS_MODEL=llama-3.1-8b-instant

# CORS allowed origins (comma-separated, default: * for development)
# ALLOWED_ORIGINS=http://localhost:8000,https://among-ai.example.com
